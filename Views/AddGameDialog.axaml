<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="using:SaveSync.Services"
        x:Class="SaveSync.Views.AddGameDialog"
        Title="Add New Game"
        Width="480"
        SizeToContent="Height"
        MaxHeight="720"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="16,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="🎮" FontSize="16" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="Add New Game"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Form body -->
        <Border Grid.Row="1" Padding="20,16">
            <StackPanel Spacing="12">

                <!-- Game Name + IGDB suggestions -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Game Name" FontWeight="SemiBold" Foreground="#2C3E50"/>
                    <TextBox x:Name="GameNameBox" Watermark="e.g. The Witcher 3"/>

                    <!-- Searching indicator -->
                    <TextBlock x:Name="SearchingText"
                               Text="Searching IGDB…"
                               FontSize="11"
                               Foreground="#7F8C8D"
                               IsVisible="False"/>

                    <!-- Suggestions dropdown -->
                    <Border x:Name="SuggestionsPanel"
                            IsVisible="False"
                            BorderBrush="#BDC3C7"
                            BorderThickness="1"
                            CornerRadius="4"
                            Background="White">
                        <ScrollViewer MaxHeight="280">
                            <ListBox x:Name="SuggestionsList"
                                     Background="Transparent"
                                     SelectionChanged="SuggestionsList_SelectionChanged">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="6,4"/>
                                        <Setter Property="CornerRadius" Value="4"/>
                                        <Setter Property="Margin" Value="4,2"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#BBDEFB"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#90CAF9"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="services:IgdbSearchResult">
                                        <Grid ColumnDefinitions="52,*"
                                              Margin="0,0,0,0">
                                            <!-- Cover art -->
                                            <Border Grid.Column="0"
                                                    Background="#ECF0F1"
                                                    Width="40" Height="52"
                                                    CornerRadius="3"
                                                    ClipToBounds="True"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">
                                                <Image Source="{Binding Cover}"
                                                       Stretch="UniformToFill"/>
                                            </Border>

                                            <!-- Title + year -->
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0,4,0"
                                                        Spacing="2">
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           Foreground="Black"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding ReleaseYear, StringFormat='{}({0})', FallbackValue=''}"
                                                           FontSize="11"
                                                           Foreground="#555555"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </Border>

                    <!-- IGDB not configured notice -->
                    <TextBlock x:Name="IgdbNotConfiguredText"
                               Text="ℹ IGDB suggestions unavailable — set IGDB_CLIENT_ID and IGDB_CLIENT_SECRET environment variables, or add credentials to config."
                               FontSize="11"
                               Foreground="#E67E22"
                               TextWrapping="Wrap"
                               IsVisible="False"/>
                </StackPanel>

                <!-- Save Directory -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Save Directory Path" FontWeight="SemiBold" Foreground="#2C3E50"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 x:Name="SavePathBox"
                                 Watermark="Path to game save folder"
                                 Margin="0,0,8,0"/>
                        <Button Grid.Column="1"
                                Content="Browse…"
                                Click="BrowseSavePathButton_Click"
                                Padding="12,6"
                                Background="#3498DB"
                                Foreground="White"/>
                    </Grid>
                </StackPanel>

                <!-- Validation error -->
                <TextBlock x:Name="ErrorText"
                           Foreground="#E74C3C"
                           FontSize="11"
                           IsVisible="False"
                           TextWrapping="Wrap"/>

            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Border Grid.Row="2" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Content="Cancel"
                        Click="Cancel_Click"
                        Padding="20,8"
                        Background="#828282"/>
                <Button Content="Add Game"
                        Background="#27AE60"
                        Foreground="White"
                        Click="AddGame_Click"
                        Padding="20,8"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
